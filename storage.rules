rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Certificados digitales de doctores (P12) — solo el dueño puede leer/escribir
    match /certificates/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Reportes de farmacia (subidos por admin) — cualquier usuario autenticado puede leer
    match /pharmacy_reports/{reportId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
